# VersionCheckBot Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit .env to git with real sensitive values!
# This file is safe to commit as it contains no secrets

# ──────────────────────────────────────────────
#  REQUIRED: Telegram Bot Token
# ──────────────────────────────────────────────
# Get token from @BotFather on Telegram
BOT_TOKEN=

# ──────────────────────────────────────────────
#  OPTIONAL: Admin Configuration
# ──────────────────────────────────────────────
# Comma-separated list of Telegram user IDs who have admin access
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ──────────────────────────────────────────────
#  OPTIONAL: NVD API Key
# ──────────────────────────────────────────────
# Get API key at: https://nvd.nist.gov/developers/request-an-api-key
# Higher rate limits for CVE queries
NVD_API_KEY=

# ──────────────────────────────────────────────
#  Database Configuration
# ──────────────────────────────────────────────
# SQLite (default): DATABASE_URL=sqlite:///./data/bot.db
# PostgreSQL:       DATABASE_URL=postgresql://user:password@localhost:5432/botdb
DATABASE_URL=sqlite:///./data/bot.db

# PostgreSQL specific (if using PostgreSQL)
POSTGRES_USER=botuser
POSTGRES_PASSWORD=
POSTGRES_DB=botdb

# ──────────────────────────────────────────────
#  Cache Configura