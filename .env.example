# ──────────────────────────────────────────────
#  VersionCheckBot — Environment Configuration
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=

# ── Optional: Administration ──────────────────
# Comma-separated Telegram user IDs for bot admins
# ADMIN_IDS=123456789,987654321

# ── Optional: NVD API ─────────────────────────
# API key for NIST NVD (higher rate limits for CVE queries)
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# ── Database ──────────────────────────────────
# SQLite (default) or PostgreSQL
# DATABASE_URL=sqlite:///./bot.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/botdb

# ── Cache TTL (seconds) ──────────────────────
# RELEASE_TTL=21600        # 6 hours
# PRODUCTS_TTL=86400       # 24 hours
# CVE_TTL=43200            # 12 hours

# ── Performance ───────────────────────────────
# MAX_PARALLEL=15           # Max concurrent API requests

# ── Rate Limits ───────────────────────────────
# RATE_LIMIT_PER_MINUTE=20
# RATE_LIMIT_PER_HOUR=200

# ── Scheduler ─────────────────────────────────
# SCHEDULER_INTERVAL=21600  # 6 hours — how often subscriptions are checked
# NOTIFICATION_ENABLED=true

# ── Logging ───────────────────────────────────
# LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
