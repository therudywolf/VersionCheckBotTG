# VersionCheckBot Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit .env to git with real sensitive values!
# This file is safe to commit as it contains no secrets

# ──────────────────────────────────────────────
#  REQUIRED: Telegram Bot Token
# ──────────────────────────────────────────────
# Get token from @BotFather on Telegram
BOT_TOKEN=

# ──────────────────────────────────────────────
#  OPTIONAL: Admin Configuration
# ──────────────────────────────────────────────
# Comma-separated list of Telegram user IDs who have admin access
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ──────────────────────────────────────────────
#  OPTIONAL: NVD API Key
# ──────────────────────────────────────────────
# Get API key at: https://nvd.nist.gov/developers/request-an-api-key
# Higher rate limits for CVE queries
NVD_API_KEY=

# ──────────────────────────────────────────────
#  Database Configuration
# ──────────────────────────────────────────────
# SQLite (default): DATABASE_URL=sqlite:///./data/bot.db
# PostgreSQL:       DATABASE_URL=postgresql://user:password@localhost:5432/botdb
DATABASE_URL=sqlite:///./data/bot.db

# PostgreSQL specific (if using PostgreSQL)
POSTGRES_USER=botuser
POSTGRES_PASSWORD=
POSTGRES_DB=botdb

# ──────────────────────────────────────────────
#  Cache Configuration
# ──────────────────────────────────────────────
CACHE_DIR=./cache

# Cache TTL in seconds
RELEASE_TTL=21600    # 6 hours  — endoflife.date release data
PRODUCTS_TTL=86400   # 24 hours — product list
CVE_TTL=43200        # 12 hours — NVD CVE records

# ──────────────────────────────────────────────
#  Performance
# ──────────────────────────────────────────────
MAX_PARALLEL=15
SCHEDULER_INTERVAL=21600

# ──────────────────────────────────────────────
#  Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=200

# ──────────────────────────────────────────────
#  Features
# ──────────────────────────────────────────────
NOTIFICATION_ENABLED=true
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
#  API endpoints (defaults — usually no need to change)
# ──────────────────────────────────────────────
EOL_API_ROOT=https://endoflife.date/api
NVD_API_ROOT=https://services.nvd.nist.gov/rest/json

# ──────────────────────────────────────────────
#  Web Admin Panel
# ──────────────────────────────────────────────
# Password to log in to the web panel
# Change this before running in production!
WEB_PASSWORD=changeme

# Secret key for JWT signing (auto-derived from BOT_TOKEN if empty)
# Set a strong random value in production: openssl rand -hex 32
WEB_SECRET_KEY=

# Web panel host/port (used by Dockerfile.web / uvicorn)
WEB_PANEL_HOST=0.0.0.0
WEB_PANEL_PORT=8000

# Comma-separated allowed CORS origins (defaults to localhost)
# WEB_CORS_ORIGINS=http://localhost:8000,https://yourdomain.com

# Path to .env file read/written by the settings page (default: .env in CWD)
# ENV_FILE=.env
